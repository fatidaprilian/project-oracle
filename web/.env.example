# Frontend API URL
# Local dev:
# VITE_API_URL=http://localhost:8000
# Production API (Cloud Run):
VITE_API_URL=https://project-oracle-133425616833.asia-southeast2.run.app

# Optional: if ORACLE_API_AUTH_ENABLED=true on backend
