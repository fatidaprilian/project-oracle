# Development/Deployment mode
ORACLE_RUNTIME_MODE=paper
ORACLE_EXCHANGE_ENV=testnet
PYTHONPATH=src

# Port for API server (Railway auto-sets $PORT, but we should support both)
PORT=8000
ORACLE_FRONTEND_URL=http://localhost:3000
ORACLE_ALLOWED_ORIGINS=http://localhost:3000

# Sentiment provider (vendor-agnostic adapter)
ORACLE_SENTIMENT_BASE_URL=
ORACLE_SENTIMENT_API_KEY=
ORACLE_SENTIMENT_TIMEOUT=5.0

# AI analyst provider settings
# allowed values: grok, gemini, custom
# gemini uses X-goog-api-key header and defaults to Google Generative Language API
ORACLE_AI_PROVIDER=gemini
ORACLE_AI_ANALYST_BASE_URL=
ORACLE_AI_ANALYST_API_KEY=
ORACLE_AI_ANALYST_TIMEOUT=10.0
ORACLE_ENABLE_AI_ANALYST_CONNECTIVITY=false
ORACLE_AI_ANALYST_HEALTH_PATH=

# Persistence toggles
ORACLE_ENABLE_POSTGRES=false
ORACLE_ENABLE_REDIS=false

# Persistence connection
ORACLE_POSTGRES_DSN=
ORACLE_REDIS_URL=

# Persistence behavior
ORACLE_PERSISTENCE_MAX_RETRIES=2
ORACLE_PERSISTENCE_RETRY_DELAY_SECONDS=0.2
ORACLE_REDIS_RISK_TTL_SECONDS=86400
ORACLE_PERSISTENCE_FALLBACK_FILE=runtime-fallback/journal-events.jsonl

# Scheduler settings (for automated weekly runs)
ORACLE_SCHEDULER_DAY_OF_WEEK=0
ORACLE_SCHEDULER_HOUR=8
ORACLE_SCHEDULER_MINUTE=0

# Exchange connectivity adapter (Phase 8)
ORACLE_ENABLE_EXCHANGE_CONNECTIVITY=false
ORACLE_EXCHANGE_PROVIDER=bybit
ORACLE_EXCHANGE_BASE_URL=
ORACLE_EXCHANGE_TIMEOUT_SECONDS=3.0

# Optional: Basic auth for API (Phase 7+)
# If enabled, frontend login uses users stored in database (auth_users table).
ORACLE_API_AUTH_ENABLED=true
ORACLE_API_AUTH_TOKEN=

# Auth database DSN (can reuse ORACLE_POSTGRES_DSN if same DB)
ORACLE_AUTH_POSTGRES_DSN=

# Password hashing strength for auth_users
ORACLE_AUTH_HASH_ITERATIONS=390000
