# Project Oracle - Environment Variables (Stock & Telegram Pivot)

# Core Settings
PORT=8000
PYTHONPATH=src
ORACLE_FRONTEND_URL=http://localhost:3000
ORACLE_ALLOWED_ORIGINS=http://localhost:3000

# Telegram Bot Integration (Required)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Public HTTPS base URL backend API, used to auto-register Telegram webhook.
# Example: https://your-api-domain.com
ORACLE_TELEGRAM_WEBHOOK_URL=

# AI Analyst Provider (Gemini 3.1 Pro)
ORACLE_AI_PROVIDER=gemini
ORACLE_AI_ANALYST_BASE_URL=
ORACLE_AI_ANALYST_API_KEY=
ORACLE_AI_ANALYST_TIMEOUT=15.0

# News API Provider (For Fundamental Checks)
# (e.g. NewsAPI, Yahoo Finance, etc.)
ORACLE_NEWS_API_PROVIDER=newsapi
ORACLE_NEWS_API_KEY=
ORACLE_NEWS_BASE_URL=

# Database / Persistence
ORACLE_ENABLE_POSTGRES=true
ORACLE_POSTGRES_DSN=
ORACLE_ENABLE_REDIS=false
ORACLE_REDIS_URL=

# Optional: API Authentication
ORACLE_API_AUTH_ENABLED=true
ORACLE_API_AUTH_TOKEN=
ORACLE_AUTH_POSTGRES_DSN=
ORACLE_AUTH_HASH_ITERATIONS=390000

# Cron Job Scheduler (Active Tracking Daemon)
ORACLE_SCHEDULER_INTERVAL_MINUTES=60
